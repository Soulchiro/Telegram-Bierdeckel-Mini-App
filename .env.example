# Copy this file to .env and fill in your own Supabase project values.
# Find these in Supabase Dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ISO country code used for the "public holiday today" lookup via the
# free Nager.Date API (https://date.nager.at). IE = Ireland, fits the pub theme.
# Full list of supported codes: https://date.nager.at/Country
VITE_HOLIDAY_COUNTRY=IE

# Optional "which pub am I at" tagging. Off by default — it went through a
# few redesigns and still didn't feel worth the added surface area. Set to
# "true" to bring it back if you want to try a different take on it.
VITE_ENABLE_PUBS=false

# Your bot's Mini App link, included in shared stats so whoever you share
# with can open the app themselves.
VITE_BOT_SHARE_URL=https://t.me/bierdeckels_bot
